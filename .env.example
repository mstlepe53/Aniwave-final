# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local MongoDB (default — works out of the box)
# Make sure MongoDB is running: net start MongoDB  (Windows)
#                               sudo systemctl start mongod  (Linux/Mac)
# MONGODB_URI is optional — defaults to localhost automatically
# MONGODB_URI=mongodb://127.0.0.1:27017/animevault

# MongoDB Atlas (cloud alternative)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/animevault?retryWrites=true&w=majority

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_any_long_random_string_min_32_chars

# ─── Site URL ────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:5000
VITE_SITE_URL=http://localhost:5000

# ─── CORS (leave empty for local dev — all origins allowed) ───────────────────
# CORS_ORIGINS=https://your-project.vercel.app
