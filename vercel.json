{
  "version": 2,
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": { "memory": 512, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|map|json))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
